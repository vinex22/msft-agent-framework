# Azure AI Foundry project endpoint
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://<your-foundry-resource>.services.ai.azure.com/api/projects/<your-project>

# Name of the model deployment in your Foundry project (e.g. gpt-4.1, gpt-5.4-mini)
MODEL_DEPLOYMENT_NAME=gpt-4.1

# Azure identity (used by DefaultAzureCredential / az CLI)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
